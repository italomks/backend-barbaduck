# Railway injeta PORT automaticamente.
PORT=3000

# URL privada do servico WAHA dentro do mesmo projeto Railway.
WAHA_URL=http://waha.railway.internal:3000
WAHA_API_KEY=gere-uma-chave-longa-e-aleatoria
WAHA_SESSION=default

# Numero que RECEBERA as solicitacoes, somente digitos com DDI e DDD.
WHATSAPP_DESTINATION=5527999999999

# Separe mais de uma origem por virgula.
ALLOWED_ORIGINS=https://barbaduck.com.br,https://www.barbaduck.com.br
